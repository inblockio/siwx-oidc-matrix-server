# siwx-oidc-matrix-server environment configuration
# Copy to .env or let start-matrix.sh generate it automatically.

#--- Required (pass via start-matrix.sh flags) ---
# MATRIX_HOST=matrix.example.com
# SIWEOIDC_HOST=siwx-oidc.example.com
# LETSENCRYPT_EMAIL=admin@example.com

#--- SIWX-OIDC ---
SIWEOIDC_PORT=8081
SIWEOIDC_BASE_URL=https://siwx-oidc.example.com
# Auto-generated if not set:
# SIWEOIDC_DEFAULT_CLIENTS='{clientid="{\"secret\":\"clientsecret\", \"metadata\": {\"redirect_uris\": [\"https://matrix.example.com/_synapse/client/oidc/callback\"]}}"}'
RUST_LOG=siwx_oidc=error,tower_http=error

#--- Matrix Synapse ---
MATRIX_PORT=8080
MATRIX_BASE_URL=https://matrix.example.com
MATRIX_REPORT_STATS=no
MATRIX_MESSAGE_LIFETIME=4w
# Auto-generated if not set:
# MATRIX_OIDC_CLIENT_ID=
# MATRIX_OIDC_SECRET_ID=

# Note: The OIDC signing key (ES256 PEM) is stored in siwx-oidc-config/siwe-oidc.toml,
# NOT in this file. It is auto-generated on first run by start-matrix.sh and mounted
# into the siwx-oidc container. This ensures tokens survive container restarts.
