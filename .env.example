# siwx-oidc-matrix-server environment configuration
# Copy to .env or let start-matrix.sh generate it automatically.

#--- Required (pass via start-matrix.sh flags) ---
# MATRIX_HOST=matrix.example.com
# SIWEOIDC_HOST=siwx-oidc.example.com
# LETSENCRYPT_EMAIL=admin@example.com

#--- SIWX-OIDC ---
SIWEOIDC_PORT=8081
SIWEOIDC_BASE_URL=https://siwx-oidc.example.com
# Auto-generated if not set:
# SIWEOIDC_DEFAULT_CLIENTS='{clientid="{\"secret\":\"clientsecret\", \"metadata\": {\"redirect_uris\": [\"https://matrix.example.com/_synapse/client/oidc/callback\"]}}"}'
# Auto-generated by start-matrix.sh (ES256 PEM, single-line \n-escaped for Docker Compose):
# SIWEOIDC_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----\n"
RUST_LOG=siwx_oidc=error,tower_http=error

#--- Matrix Synapse ---
MATRIX_PORT=8080
MATRIX_BASE_URL=https://matrix.example.com
MATRIX_REPORT_STATS=no
MATRIX_MESSAGE_LIFETIME=4w
# Auto-generated if not set:
# MATRIX_OIDC_CLIENT_ID=
# MATRIX_OIDC_SECRET_ID=

# Optional: auto-promote this DID to server admin on every boot (idempotent).
# The user must complete at least one OIDC login before promotion takes effect.
# MATRIX_ADMIN_DID=did:pkh:eip155:1:0xYourEthereumAddress

# Note: SIWEOIDC_SIGNING_KEY_PEM is auto-generated by start-matrix.sh and written to
# .env (chmod 600). It is passed to the container via environment variable — no file on
# disk. Do not delete it from .env; tokens become invalid if the key changes.
